{
  "manifest_version": 3,
  "name": "Capsule Save",
  "version": "1.3.5",
  "description": "Save Claude conversations to Capsule. Surfaces related memory automatically.",
  "permissions": ["activeTab", "storage", "sidePanel", "tabs", "alarms"],
  "host_permissions": [
    "https://claude.ai/*",
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*",
    "<all_urls>"
  ],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "64": "icon64.png",
      "128": "icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content.js"]
    }
  ]
}
